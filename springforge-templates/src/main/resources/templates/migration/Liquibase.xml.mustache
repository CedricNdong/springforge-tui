<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="create-{{entity.tableName}}" author="springforge">
        <createTable tableName="{{entity.tableName}}">
{{#entity.columns}}
            <column name="{{columnName}}" type="{{columnType}}"{{#isPrimaryKey}} autoIncrement="true"{{/isPrimaryKey}}>
                <constraints{{#isPrimaryKey}} primaryKey="true"{{/isPrimaryKey}}{{#isNullable}} nullable="true"{{/isNullable}}{{^isNullable}} nullable="false"{{/isNullable}}{{#isUnique}} unique="true"{{/isUnique}}/>
            </column>
{{/entity.columns}}
        </createTable>
    </changeSet>
</databaseChangeLog>
